{
  "Kafka": {
    "BootstrapServers": "kafka:9092"
  },
  "Services": {
    "InventoryBaseUrl": "http://inventoryservice:8080",
    "PaymentBaseUrl": "http://paymentservice:8080",
    "OrderBaseUrl": "http://orderservice:8080"
  },
  "Resilience": {
    "Default": {
      "RetryCount": 3,
      "BaseDelaySeconds": 2,
      "CircuitBreakerFailures": 5,
      "CircuitBreakerDurationSeconds": 30
    },
    "Inventory": {
      "RetryCount": 2
    },
    "Payment": {
      "CircuitBreakerFailures": 3
    },
    "Order": {
      "CircuitBreakerDurationSeconds": 20
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
