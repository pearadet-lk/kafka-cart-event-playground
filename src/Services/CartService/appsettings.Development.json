{
  "Kafka": {
    "BootstrapServers": "localhost:9092"
  },
  "Services": {
    "InventoryBaseUrl": "http://localhost:5003",
    "PaymentBaseUrl": "http://localhost:5004",
    "OrderBaseUrl": "http://localhost:5005"
  },
  "Resilience": {
    "Default": {
